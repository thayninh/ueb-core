    "phase7:bootstrap-production-target": "node --import tsx scripts/phase-7/production-target.ts bootstrap",
    "phase7:verify-production-target": "node --import tsx scripts/phase-7/production-target.ts verify",
    "phase7:reconcile-production-identities": "node --import tsx scripts/phase-7/production-target.ts reconcile-identities",
    "phase7:apply-production-identities": "node --import tsx scripts/phase-7/apply-production-identities.ts",
    "phase7:backup-production-target": "node --import tsx scripts/phase-7/production-target.ts backup",
    "phase7:restore-production-rehearsal": "node --import tsx scripts/phase-7/production-target.ts restore",
    "phase7:cleanup-production-restore": "node --import tsx scripts/phase-7/production-target.ts cleanup-restore",
    "phase4:grant-runtime-permissions": "tsx scripts/phase-4/grant-workflow-runtime-permissions.ts",
    "phase5:backup": "tsx scripts/phase-5/backup-database.ts",
    "phase5:restore-rehearsal": "tsx scripts/phase-5/restore-rehearsal.ts",
    "phase5:cleanup-restore": "tsx scripts/phase-5/cleanup-restore-database.ts",
    "phase5:bootstrap-uat": "tsx scripts/phase-5/bootstrap-uat-database.ts",
    "phase5:verify-uat-baseline": "tsx scripts/phase-5/verify-uat-baseline.ts",
    "phase5:revoke-uat-sessions": "tsx scripts/phase-5/revoke-uat-sessions.ts",
    "phase5:lookup-active-admin": "tsx scripts/phase-5/lookup-active-admin.ts",
    "phase5:fingerprint-database": "tsx scripts/phase-5/fingerprint-database.ts",
    "phase5:cleanup-uat": "tsx scripts/phase-5/cleanup-uat-database.ts",
    "phase5:validate-identities": "tsx scripts/phase-5/validate-identity-input.ts",
    "phase5:provision-users": "NODE_OPTIONS=--conditions=react-server tsx scripts/phase-5/provision-approved-users.ts",
    "phase5:reconcile-provisioning": "NODE_OPTIONS=--conditions=react-server tsx scripts/phase-5/reconcile-provisioning-batch.ts",
    "phase5:rollback-provisioning": "NODE_OPTIONS=--conditions=react-server tsx scripts/phase-5/rollback-provisioning-batch.ts",
    "phase5:bootstrap-provisioning-role": "tsx scripts/phase-5/bootstrap-provisioning-role.ts",
    "phase5:grant-provisioning-permissions": "tsx scripts/phase-5/grant-provisioning-permissions.ts",
    "phase5:verify-provisioning-role": "tsx scripts/phase-5/verify-provisioning-role.ts",
    "phase5:reconcile-pilot-uat": "tsx scripts/phase-5/reconcile-pilot-uat.ts",
    "phase6:bootstrap-staging-database": "tsx scripts/phase-6/staging-operations.ts bootstrap-database",
    "phase6:bootstrap-staging-runtime-role": "tsx scripts/phase-6/staging-operations.ts bootstrap-runtime-role",
    "phase6:bootstrap-staging-provisioning-role": "tsx scripts/phase-6/staging-operations.ts bootstrap-provisioning-role",
    "phase6:grant-staging-runtime-permissions": "tsx scripts/phase-6/staging-operations.ts grant-runtime-permissions",
    "phase6:grant-staging-provisioning-permissions": "tsx scripts/phase-6/staging-operations.ts grant-provisioning-permissions",
    "phase6:verify-staging-security": "tsx scripts/phase-6/staging-operations.ts verify-security",
    "phase6:fingerprint-staging": "tsx scripts/phase-6/staging-operations.ts fingerprint",
    "phase6:backup-staging": "tsx scripts/phase-6/staging-operations.ts backup",
    "phase6:verify-staging-backup": "tsx scripts/phase-6/staging-operations.ts verify-backup",
    "phase6:cleanup-staging-backups": "tsx scripts/phase-6/staging-operations.ts cleanup-backups",
    "phase6:restore-staging-rehearsal": "tsx scripts/phase-6/staging-operations.ts restore-rehearsal",
    "phase6:verify-staging-restore": "tsx scripts/phase-6/staging-operations.ts verify-restore",
    "phase6:cleanup-staging-restore": "tsx scripts/phase-6/staging-operations.ts cleanup-restore",
    "phase6:clear-stale-staging-restore-lock": "tsx scripts/phase-6/staging-operations.ts clear-stale-restore-lock",
    "phase6:staging-deployment-preflight": "tsx scripts/phase-6/staging-operations.ts deployment-preflight",
    "phase6:verify-rollback-image": "tsx scripts/phase-6/staging-operations.ts verify-rollback-image",
    "phase6:generate-staging-secrets": "tsx scripts/phase-6/staging-secrets.ts generate",
    "phase6:validate-staging-secrets": "tsx scripts/phase-6/staging-secrets.ts validate",
    "phase6:operator-local-execution-test": "tsx scripts/phase-6/operator-local-execution-test.ts",
    "data:inspect": "tsx scripts/phase-2/inspect-source.ts",
    "data:profile-column": "tsx scripts/phase-2/profile-column.ts",
    "data:dry-run": "tsx scripts/phase-2/dry-run-import.ts",
    "data:import": "tsx scripts/phase-2/import-source.ts",
    "data:verify": "tsx scripts/phase-2/verify-import.ts",
    "auth:inspect-identities": "tsx scripts/phase-3/inspect-identity-source.ts",
    "auth:seed-units": "tsx scripts/phase-3/seed-organization-units.ts",
    "auth:bootstrap-admin": "tsx scripts/phase-3/bootstrap-admin.ts",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:format": "prisma format",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:status": "prisma migrate status",
    "db:bootstrap-runtime-role": "tsx scripts/phase-2/bootstrap-runtime-role.ts",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
