{
  "name": "ueb-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "pnpm db:generate && next dev",
    "build": "pnpm db:generate && next build",
    "start": "next start",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint",
    "typecheck": "pnpm db:generate && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "tsx scripts/phase-3/prepare-test-databases.ts --confirm-reset-phase3-test-databases && playwright test --config playwright.phase-3.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:phase3:prepare": "tsx scripts/phase-3/prepare-test-databases.ts --confirm-reset-phase3-test-databases",
    "test:phase3:integration": "PHASE3_ISOLATED_INTEGRATION=1 vitest run tests/phase-3/core-read-rls.integration.test.ts",
    "test:phase3:e2e": "pnpm test:phase3:prepare && playwright test --config=playwright.phase-3.config.ts",
    "test:phase3": "pnpm test:phase3:prepare && pnpm test:phase3:integration && playwright test --config=playwright.phase-3.config.ts",
    "test:phase3:rehearsal": "tsx scripts/phase-3/run-full-rehearsal.ts --confirm-full-phase3-rehearsal",
    "test:phase4:lecturer:prepare": "tsx scripts/phase-4/prepare-lecturer-portal-test-database.ts --confirm-reset-phase4-lecturer-portal",
    "test:phase4:lecturer:e2e": "tsx scripts/phase-4/run-lecturer-portal-e2e.ts --confirm-reset-phase4-lecturer-portal",
    "test:phase4:leader:integration": "PHASE4_LEADER_INTEGRATION=1 vitest run --fileParallelism=false tests/phase-4/leader-submission-query.integration.test.ts tests/phase-4/workflow-reject.integration.test.ts",
    "test:phase4:leader:e2e": "tsx scripts/phase-4/run-leader-reject-e2e.ts --confirm-reset-phase4-leader-reject",
    "test:phase4:resubmission:e2e": "tsx scripts/phase-4/run-resubmission-e2e.ts --confirm-reset-phase4-resubmission",
    "test:phase4:approval:integration": "PHASE4_APPROVAL_INTEGRATION=1 vitest run --fileParallelism=false tests/phase-4/workflow-approve.integration.test.ts tests/phase-4/workflow-approval-concurrency.integration.test.ts tests/phase-4/core-approved-insert-policy.integration.test.ts",
    "test:phase4:approval:e2e": "tsx scripts/phase-4/run-leader-approve-e2e.ts --confirm-reset-phase4-leader-approve",
    "test:phase4:unit": "vitest run tests/phase-4 --exclude='tests/phase-4/**/*.integration.test.ts'",
    "test:phase4:integration": "PHASE4_ISOLATED_INTEGRATION=1 vitest run --fileParallelism=false tests/phase-4/latest-core-data.integration.test.ts && PHASE4_WORKFLOW_RLS_INTEGRATION=1 vitest run --fileParallelism=false tests/phase-4/workflow-event-rls.integration.test.ts && vitest run --fileParallelism=false tests/phase-4/workflow-submit.integration.test.ts && vitest run --fileParallelism=false tests/phase-4/lecturer-submission-query.integration.test.ts && pnpm test:phase4:leader:integration && pnpm test:phase4:approval:integration && vitest run --fileParallelism=false tests/phase-4/lecturer-resubmission-query.integration.test.ts && PHASE4_RUNTIME_PERMISSION_INTEGRATION=1 vitest run --fileParallelism=false tests/phase-4/runtime-permission-reconciliation.integration.test.ts",
    "test:phase4:e2e": "pnpm test:phase4:lecturer:e2e && pnpm test:phase4:leader:e2e && pnpm test:phase4:approval:e2e && pnpm test:phase4:resubmission:e2e",
    "test:phase4": "pnpm test:phase4:unit && pnpm test:phase4:integration && pnpm test:phase4:e2e",
    "test:phase5:provisioning-role:integration": "PHASE5_PROVISIONING_ROLE_INTEGRATION=1 vitest run --fileParallelism=false tests/phase-5/provisioning-role.integration.test.ts",
    "test:phase6:integration": "PHASE6_STAGING_INTEGRATION=1 vitest run --fileParallelism=false tests/phase-6/staging-database-ownership.integration.test.ts tests/phase-6/staging-security.integration.test.ts",
    "test:phase7:integration": "PHASE7_PASSWORD_CHANGE_INTEGRATION=1 vitest run --fileParallelism=false tests/phase-7/forced-password-change.integration.test.ts",
    "test:phase7:e2e": "tsx scripts/phase-7/run-password-change-e2e.ts --confirm-reset-phase7-password-change",
    "test:phase7:migration-diff": "tsx scripts/phase-7/run-migration-diff.ts",
    "phase7:identity-dry-run": "node --import tsx scripts/phase-7/production-identity-check.ts dry-run",
    "phase7:identity-reconcile": "node --import tsx scripts/phase-7/production-identity-check.ts reconcile",
    "phase7:initialize-production-inputs": "node --import tsx scripts/phase-7/initialize-production-identity-inputs.ts",
