{
  "name": "ueb-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "pnpm db:generate && next dev",
    "build": "pnpm db:generate && next build",
    "start": "next start",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint",
    "typecheck": "pnpm db:generate && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "tsx scripts/phase-3/prepare-test-databases.ts --confirm-reset-phase3-test-databases && playwright test --config playwright.phase-3.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:phase3:prepare": "tsx scripts/phase-3/prepare-test-databases.ts --confirm-reset-phase3-test-databases",
    "test:phase3:integration": "PHASE3_ISOLATED_INTEGRATION=1 vitest run tests/phase-3/core-read-rls.integration.test.ts",
    "test:phase3:e2e": "pnpm test:phase3:prepare && playwright test --config=playwright.phase-3.config.ts",
    "test:phase3": "pnpm test:phase3:prepare && pnpm test:phase3:integration && playwright test --config=playwright.phase-3.config.ts",
    "test:phase3:rehearsal": "tsx scripts/phase-3/run-full-rehearsal.ts --confirm-full-phase3-rehearsal",
    "test:phase4:lecturer:prepare": "tsx scripts/phase-4/prepare-lecturer-portal-test-database.ts --confirm-reset-phase4-lecturer-portal",
    "test:phase4:lecturer:e2e": "tsx scripts/phase-4/run-lecturer-portal-e2e.ts --confirm-reset-phase4-lecturer-portal",
    "test:phase4:leader:integration": "PHASE4_LEADER_INTEGRATION=1 vitest run --fileParallelism=false tests/phase-4/leader-submission-query.integration.test.ts tests/phase-4/workflow-reject.integration.test.ts",
    "test:phase4:leader:e2e": "tsx scripts/phase-4/run-leader-reject-e2e.ts --confirm-reset-phase4-leader-reject",
    "data:inspect": "tsx scripts/phase-2/inspect-source.ts",
    "data:profile-column": "tsx scripts/phase-2/profile-column.ts",
    "data:dry-run": "tsx scripts/phase-2/dry-run-import.ts",
    "data:import": "tsx scripts/phase-2/import-source.ts",
    "data:verify": "tsx scripts/phase-2/verify-import.ts",
    "auth:inspect-identities": "tsx scripts/phase-3/inspect-identity-source.ts",
    "auth:seed-units": "tsx scripts/phase-3/seed-organization-units.ts",
    "auth:bootstrap-admin": "tsx scripts/phase-3/bootstrap-admin.ts",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:format": "prisma format",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:status": "prisma migrate status",
    "db:bootstrap-runtime-role": "tsx scripts/phase-2/bootstrap-runtime-role.ts",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.23",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
