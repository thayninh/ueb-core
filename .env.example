# Application
APP_PORT=3000

# Local PostgreSQL
POSTGRES_DB=ueb_core
POSTGRES_USER=ueb_core_owner
POSTGRES_PASSWORD=local_owner_only_change_me
POSTGRES_PORT=55432

# Local migration/owner credential; never use this value for Next.js runtime.
MIGRATION_DATABASE_URL=postgresql://ueb_core_owner:local_owner_only_change_me@127.0.0.1:55432/ueb_core

# Local application runtime role, created by db:bootstrap-runtime-role.
APP_DATABASE_USER=ueb_core_app
APP_DATABASE_PASSWORD=local_app_only_change_me

# Used only by Next.js when it runs directly on the host machine.
DATABASE_URL=postgresql://ueb_core_app:local_app_only_change_me@127.0.0.1:55432/ueb_core
