# Application
APP_PORT=3000

# Local PostgreSQL
POSTGRES_DB=ueb_core
POSTGRES_USER=ueb_core_owner
POSTGRES_PASSWORD=local_owner_only_change_me
POSTGRES_PORT=55432

# Local migration/owner credential; never use this value for Next.js runtime.
MIGRATION_DATABASE_URL=postgresql://ueb_core_owner:local_owner_only_change_me@127.0.0.1:55432/ueb_core

# Local application runtime role, created by db:bootstrap-runtime-role.
APP_DATABASE_USER=ueb_core_app
APP_DATABASE_PASSWORD=local_app_only_change_me

# Used only by Next.js when it runs directly on the host machine.
DATABASE_URL=postgresql://ueb_core_app:local_app_only_change_me@127.0.0.1:55432/ueb_core

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace_with_local_secret
AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Phase 3 one-time bootstrap
BOOTSTRAP_ADMIN_EMAIL=admin@example.invalid
BOOTSTRAP_ADMIN_PASSWORD=replace_with_local_password
BOOTSTRAP_ADMIN_NAME=Local Administrator

# Used to hash identifiers in security audit logs
AUDIT_HMAC_SECRET=replace_with_local_audit_secret

# Phase 3 isolated test fixtures (local fake identities only)
PHASE3_FIXTURE_PASSWORD=replace_with_local_test_password
PHASE3_FIXTURE_ADMIN_EMAIL=phase3-admin@example.invalid
PHASE3_FIXTURE_LECTURER_A_EMAIL=phase3-lecturer-a@example.invalid
PHASE3_FIXTURE_LECTURER_B_EMAIL=phase3-lecturer-b@example.invalid
PHASE3_FIXTURE_LEADER_A_EMAIL=phase3-leader-a@example.invalid
PHASE3_FIXTURE_LEADER_MULTI_UNIT_EMAIL=phase3-leader-multi@example.invalid
PHASE3_FIXTURE_DISABLED_USER_EMAIL=phase3-disabled@example.invalid
PHASE3_FIXTURE_NEW_USER_EMAIL=phase3-new-user@example.invalid
