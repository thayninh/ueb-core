generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "esm"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

model UebCoreData {
  stt Int @id @default(autoincrement())

  donViPhuTrachHocPhan          String? @map("don_vi_phu_trach_hoc_phan") @db.Text
  boMonPhuTrachHocPhan          String? @map("bo_mon_phu_trach_hoc_phan") @db.Text
  khoiKienThuc                  Int     @map("khoi_kien_thuc") @db.Integer
  maHocPhan                     String? @map("ma_hoc_phan") @db.Text
  tenHocPhan                    String? @map("ten_hoc_phan") @db.Text
  tenGiangVien                  String? @map("ten_giang_vien") @db.Text
  maSoCanBo                     String? @map("ma_so_can_bo") @db.Text
  emailTaiKhoanVnu              String? @map("email_tai_khoan_vnu") @db.Text
  boMon                         String? @map("bo_mon") @db.Text
  donVi                         String? @map("don_vi") @db.Text
  core123                       String? @map("core_1_2_3") @db.Text
  tc1TroGiang                   String? @map("tc1_tro_giang") @db.Text
  tc2ShChuyenMon                String? @map("tc2_sh_chuyen_mon") @db.Text
  tc3TongHop                    String? @map("tc3_tong_hop") @db.Text
  tc31NganhTotNghiepPhuHop      String? @map("tc3_1_nganh_tot_nghiep_phu_hop") @db.Text
  tc32BienSoanDeCuongGiaoTrinh  String? @map("tc3_2_bien_soan_de_cuong_giao_trinh") @db.Text
  tc33ChuNhiemDeTaiNckhLienQuan String? @map("tc3_3_chu_nhiem_de_tai_nckh_lien_quan") @db.Text
  tc34BaiBaoLienQuan            String? @map("tc3_4_bai_bao_lien_quan") @db.Text
  tc4GiangThu                   String? @map("tc4_giang_thu") @db.Text

  lecturerUid        String   @map("lecturer_uid") @db.Uuid
  recordUid          String   @map("record_uid") @db.Uuid
  snapshotId         String   @map("snapshot_id") @db.Uuid
  versionNo          Int      @map("version_no")
  identityStatus     String   @map("identity_status") @db.VarChar(16)
  sourceRowNumber    Int      @map("source_row_number")
  sourceRowChecksum  String   @map("source_row_checksum") @db.Char(64)
  sourceImportRunId  String   @map("source_import_run_id") @db.Uuid
  sourceSubmissionId String?  @map("source_submission_id") @db.Uuid
  approvalUnit       String?  @map("approval_unit") @db.Text
  origin             String   @db.VarChar(32)
  approvedBy         String?  @map("approved_by") @db.Uuid
  approvedAt         DateTime @map("approved_at") @db.Timestamptz(6)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  sourceImportRun ImportRun @relation(fields: [sourceImportRunId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([recordUid, snapshotId], map: "ueb_core_data_record_uid_snapshot_id_key")
  @@unique([lecturerUid, versionNo, recordUid], map: "ueb_core_data_lecturer_uid_version_no_record_uid_key")
  @@index([lecturerUid, stt(sort: Desc)], map: "ueb_core_data_lecturer_uid_stt_idx")
  @@index([snapshotId], map: "ueb_core_data_snapshot_id_idx")
  @@index([maSoCanBo], map: "ueb_core_data_ma_so_can_bo_idx")
  @@index([emailTaiKhoanVnu], map: "ueb_core_data_email_tai_khoan_vnu_idx")
  @@index([approvalUnit], map: "ueb_core_data_approval_unit_idx")
  @@map("ueb_core_data")
}

model ImportRun {
  id                     String   @id @default(uuid()) @db.Uuid
  sourceFilename         String   @map("source_filename") @db.Text
  sourceSha256           String   @unique(map: "import_run_source_sha256_key") @map("source_sha256") @db.Char(64)
  sourceSheet            String   @map("source_sheet") @db.Text
  sourceContractVersion  String   @map("source_contract_version") @db.VarChar(32)
  sourceRowCount         Int      @map("source_row_count")
  sourceMinStt           Int      @map("source_min_stt")
  sourceMaxStt           Int      @map("source_max_stt")
  canonicalDatasetSha256 String   @map("canonical_dataset_sha256") @db.Char(64)
  report                 Json     @db.JsonB
  importedAt             DateTime @map("imported_at") @db.Timestamptz(6)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  dataRows UebCoreData[]

  @@map("import_run")
}

model WorkflowEvent {
  eventId            String                  @id @default(uuid()) @map("event_id") @db.Uuid
  submissionId       String                  @map("submission_id") @db.Uuid
  parentSubmissionId String?                 @map("parent_submission_id") @db.Uuid
  eventType          WorkflowEventType       @map("event_type")
  submissionType     WorkflowSubmissionType? @map("submission_type")
  recordUid          String?                 @map("record_uid") @db.Uuid
  lecturerUid        String                  @map("lecturer_uid") @db.Uuid
  approvalUnit       String?                 @map("approval_unit") @db.Text
  baseStt            Int?                    @map("base_stt")
  baseVersionNo      Int?                    @map("base_version_no")
  payload            Json?                   @db.JsonB
  payloadChecksum    String?                 @map("payload_checksum") @db.Text
  actorUserId        String?                 @map("actor_user_id") @db.Uuid
  reason             String?                 @db.Text
  resultStt          Int?                    @map("result_stt")
  resultVersionNo    Int?                    @map("result_version_no")
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([submissionId, createdAt], map: "workflow_event_submission_id_created_at_idx")
  @@index([lecturerUid, createdAt], map: "workflow_event_lecturer_uid_created_at_idx")
  @@index([lecturerUid, recordUid, createdAt], map: "workflow_event_lecturer_uid_record_uid_created_at_idx")
  @@index([approvalUnit, createdAt], map: "workflow_event_approval_unit_created_at_idx")
  @@index([eventType, createdAt], map: "workflow_event_event_type_created_at_idx")
  @@index([recordUid, createdAt], map: "workflow_event_record_uid_created_at_idx")
  @@index([parentSubmissionId, createdAt], map: "workflow_event_parent_submission_id_created_at_idx")
  @@map("workflow_event")
}

model Auth_user {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  email         String
  emailVerified Boolean        @default(false)
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  auth_sessions Auth_session[]
  auth_accounts Auth_account[]

  accessProfile               AccessProfile?        @relation("AccessProfileUser")
  createdAccessProfiles       AccessProfile[]       @relation("AccessProfileCreatedBy")
  roleAssignments             RoleAssignment[]      @relation("RoleAssignmentUser")
  grantedRoleAssignments      RoleAssignment[]      @relation("RoleAssignmentGrantedBy")
  revokedRoleAssignments      RoleAssignment[]      @relation("RoleAssignmentRevokedBy")
  unitScopeAssignments        UnitScopeAssignment[] @relation("UnitScopeAssignmentUser")
  grantedUnitScopeAssignments UnitScopeAssignment[] @relation("UnitScopeAssignmentGrantedBy")
  revokedUnitScopeAssignments UnitScopeAssignment[] @relation("UnitScopeAssignmentRevokedBy")

  @@unique([email])
  @@map("auth_user")
}

model Auth_session {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expiresAt DateTime
  token     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  ipAddress String?
  userAgent String?
  userId    String    @db.Uuid
  auth_user Auth_user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("auth_session")
}

model Auth_account {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  auth_user             Auth_user @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("auth_account")
}

model Auth_verification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("auth_verification")
}

model AccessProfile {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @unique(map: "access_profile_user_id_key") @map("user_id") @db.Uuid
  lecturerUid String?             @unique(map: "access_profile_lecturer_uid_key") @map("lecturer_uid") @db.Uuid
  status      AccessProfileStatus @default(PENDING_MAPPING)
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy   String              @map("created_by") @db.Uuid

  user          Auth_user @relation("AccessProfileUser", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdByUser Auth_user @relation("AccessProfileCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([status], map: "access_profile_status_idx")
  @@map("access_profile")
}

model RoleAssignment {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  role      BusinessRole
  grantedBy String       @map("granted_by") @db.Uuid
  grantedAt DateTime     @default(now()) @map("granted_at") @db.Timestamptz(6)
  revokedBy String?      @map("revoked_by") @db.Uuid
  revokedAt DateTime?    @map("revoked_at") @db.Timestamptz(6)

  user          Auth_user  @relation("RoleAssignmentUser", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  grantedByUser Auth_user  @relation("RoleAssignmentGrantedBy", fields: [grantedBy], references: [id], onDelete: Restrict, onUpdate: Cascade)
  revokedByUser Auth_user? @relation("RoleAssignmentRevokedBy", fields: [revokedBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId], map: "role_assignment_user_id_idx")
  @@index([role], map: "role_assignment_role_idx")
  @@map("role_assignment")
}

model OrganizationUnit {
  id               String                @id @default(uuid()) @db.Uuid
  unitKey          String                @unique(map: "organization_unit_unit_key_key") @map("unit_key") @db.VarChar(64)
  sourceValue      String                @unique(map: "organization_unit_source_value_key") @map("source_value") @db.Text
  displayName      String                @map("display_name") @db.Text
  isActive         Boolean               @default(true) @map("is_active")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  scopeAssignments UnitScopeAssignment[]

  @@index([isActive], map: "organization_unit_is_active_idx")
  @@map("organization_unit")
}

model UnitScopeAssignment {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  organizationUnitId String    @map("organization_unit_id") @db.Uuid
  grantedBy          String    @map("granted_by") @db.Uuid
  grantedAt          DateTime  @default(now()) @map("granted_at") @db.Timestamptz(6)
  revokedBy          String?   @map("revoked_by") @db.Uuid
  revokedAt          DateTime? @map("revoked_at") @db.Timestamptz(6)

  user             Auth_user        @relation("UnitScopeAssignmentUser", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organizationUnit OrganizationUnit @relation(fields: [organizationUnitId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  grantedByUser    Auth_user        @relation("UnitScopeAssignmentGrantedBy", fields: [grantedBy], references: [id], onDelete: Restrict, onUpdate: Cascade)
  revokedByUser    Auth_user?       @relation("UnitScopeAssignmentRevokedBy", fields: [revokedBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId], map: "unit_scope_assignment_user_id_idx")
  @@index([organizationUnitId], map: "unit_scope_assignment_organization_unit_id_idx")
  @@map("unit_scope_assignment")
}

model AuthAuditEvent {
  id             String   @id @default(uuid()) @db.Uuid
  eventType      String   @map("event_type") @db.VarChar(64)
  outcome        String   @db.VarChar(32)
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  targetUserId   String?  @map("target_user_id") @db.Uuid
  sessionId      String?  @map("session_id") @db.Uuid
  identifierHash String?  @map("identifier_hash") @db.Char(64)
  metadata       Json     @db.JsonB
  occurredAt     DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  @@index([eventType, occurredAt(sort: Desc)], map: "auth_audit_event_type_occurred_at_idx")
  @@index([actorUserId, occurredAt(sort: Desc)], map: "auth_audit_event_actor_user_id_occurred_at_idx")
  @@index([targetUserId, occurredAt(sort: Desc)], map: "auth_audit_event_target_user_id_occurred_at_idx")
  @@index([sessionId], map: "auth_audit_event_session_id_idx")
  @@map("auth_audit_event")
}

enum AccessProfileStatus {
  PENDING_MAPPING
  ACTIVE
  DISABLED

  @@map("access_profile_status")
}

enum BusinessRole {
  LECTURER
  FACULTY_LEADER
  ADMIN

  @@map("business_role")
}

enum WorkflowEventType {
  SUBMITTED
  REJECTED
  APPROVED

  @@map("workflow_event_type")
}

enum WorkflowSubmissionType {
  CONFIRM_UNCHANGED
  UPDATE_EXISTING
  CREATE_NEW

  @@map("workflow_submission_type")
}
