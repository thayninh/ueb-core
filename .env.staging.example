# Image and infrastructure identifiers (non-secret examples only)
UEB_CORE_IMAGE=ueb-core@sha256:<approved-image-digest>
CADDY_NETWORK_NAME=ueb-core-staging-proxy
STAGING_DB_VOLUME_NAME=ueb-core-staging-pgdata
STAGING_APP_CPU_LIMIT=1.0
STAGING_APP_MEMORY_LIMIT=768m
STAGING_DB_CPU_LIMIT=2.0
STAGING_DB_MEMORY_LIMIT=2g
STAGING_LOG_MAX_SIZE=10m
STAGING_LOG_MAX_FILES=5

# PostgreSQL service bootstrap (owner secret; operator scope only)
POSTGRES_DB=<staging-database-name>
POSTGRES_USER=<staging-owner-role>
POSTGRES_PASSWORD=<secret-store-reference>

# Application runtime (the only database/auth environment passed to app)
DATABASE_URL=postgresql://<dedicated-runtime-role>:<url-encoded-runtime-password>@db:5432/<staging-database-name>
BETTER_AUTH_SECRET=<secret-store-reference-minimum-32-characters>
BETTER_AUTH_URL=https://ueb-core.cargis.vn
AUTH_TRUSTED_ORIGINS=https://ueb-core.cargis.vn
AUDIT_HMAC_SECRET=<independent-secret-store-reference-minimum-32-characters>

# Migration/operator environment (never pass to app)
MIGRATION_DATABASE_URL=postgresql://<staging-owner-role>:<url-encoded-owner-password>@<private-database-endpoint>:5432/<staging-database-name>
APP_DATABASE_USER=<dedicated-runtime-role>
APP_DATABASE_PASSWORD=<dedicated-runtime-password>

# Controlled provisioning environment (never pass to app)
PHASE5_PROVISIONING_DATABASE_URL=postgresql://<dedicated-provisioning-role>:<url-encoded-provisioning-password>@<private-database-endpoint>:5432/<staging-database-name>
PHASE5_PROVISIONING_USER=<dedicated-provisioning-role>

# PHASE5_PROVISIONING_PASSWORD is injected ephemerally only when an approved
# role-bootstrap operator job requires it; do not persist it in this file.
